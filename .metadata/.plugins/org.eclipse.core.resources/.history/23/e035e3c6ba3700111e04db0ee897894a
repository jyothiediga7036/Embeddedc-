#include<cstdint>
#include"stm32f407.h"

class EXTI
{
public:
	void EXTI3_init()
	{
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
		RCC->AHB1ENR|=(1<<1);  //gpiob
		RCC->AHB1ENR|=(1<<3);  // gpiod

		GPIOD->MODER&=~(3<<24);
		GPIOD->MODER|=(1<<24);
		GPIOB->MODER &= ~(3 << (3 * 2));
		GPIOB->PUPDR &= ~(3 << (3 * 2));
		GPIOB->PUPDR |=  (2 << (3 * 2));  // Pull-down

		SYSCFG->EXTICR[0]&=~(0xf<<12);
		SYSCFG->EXTICR[0]|=(1<<12);    //PB3

		EXTI->IMR|=(1<<3);
		EXTI->RTSR|=(1<<3);

		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
        *piser|=(1<<9);  // NVIC_ISER|=(1<<7);
	}
	void EXTI4_init()
	{
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
		RCC->AHB1ENR|=(1<<2);  //gpioc
		RCC->AHB1ENR|=(1<<3);  // gpiod

		GPIOD_>MODER&=~(3<<28);
		GPIOD->MODER|=(1<<28);
		GPIOB->MODER &= ~(3 << (4 * 2));
		GPIOB->PUPDR &= ~(3 << (4 * 2));
		GPIOB->PUPDR |=  (2 << (4 * 2));  // Pull-down

		SYSCFG->EXTICR[1]&=~(0xf<<0);
		SYSCFG->EXTICR[1]|=(0x2<<0);    //PC4

		EXTI->IMR|=(1<<4);   //  enable interrupt
		EXTI->RTSR|=(1<<4);  // raising edge  trigger input

		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
		        *piser|=(1<<10);  // NVIC_ISER|=(1<<7);
	}
};

extern "C" void EXTI3_IRQHandler(void)
{
    if (EXTI->PR & (1 << 3))  // / test triggered occur or not 1-> occur 0-> not occure
    {
        GPIOD->ODR|=(1<<12);

        EXTI->PR |= (1 << 3); // Clear pending
    }
}
extern "C" void EXTI4_IRQHandler(void)
{
    if (EXTI->PR & (1 << 4))  // / test triggered occur or not 1-> occur 0-> not occure
    {
       GPIOD->ODR|=(1<<14);

        EXTI->PR |= (1 << 4); // Clear pending
    }
}


