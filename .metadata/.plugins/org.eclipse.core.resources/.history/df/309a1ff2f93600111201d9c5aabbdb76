#include<cstdint>
#include"stm32f407.h"
void led_init()
{
	RCC->AHB1ENR|=(1<<3);  // gpiod
	RCC->AHB1ENR|=(1<<0);  // gpioa
	GPIOA->MODER&=~(3<<0);
	GPIOD->MODER&=~(3<<24);
	GPIOD->MODER|=(1<<24);
}
void delay()
{
	for(volatile uint32_t i=0;i<50000;i++);
}
