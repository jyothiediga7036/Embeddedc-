#include <cstdint>
#include "stm32f407.h"
#include <string>

std::string s1, s2;

void USART2_read_str(char *s);
void init();
void delay(int n);
void USART2_write(uint8_t ch);
void USART2_write_str(const char *s);
uint8_t USART2_read(void);
void USART2_PASS();

int main()
{
    init();
    char str[50];

    while (1)
    {
        USART2_write_str("Jyothi");
        USART2_read_str(str);
        USART2_PASS();
    }
}

void init()
{
    RCC->APB1ENR |= (1 << 17);  // usart2
    RCC->AHB1ENR |= (1 << 0);   // gpioa
    RCC->AHB1ENR |= (1 << 3);   // gpiod

    GPIOA->MODER &= ~(3 << 4);
    GPIOA->MODER |= (2 << 4);

    GPIOA->MODER &= ~(3 << 6);
    GPIOA->MODER |= (2 << 6);

    GPIOA->AFR[0] &= ~(0xFU << 8);
    GPIOA->AFR[0] |= (7U << 8);   // AF7

    GPIOA->AFR[0] &= ~(0xFU << 12);
    GPIOA->AFR[0] |= (7U << 12);  // AF7

    GPIOD->MODER &= ~(3 << 26);
    GPIOD->MODER |= (1 << 26);  // green

    GPIOD->MODER &= ~(3 << 28);
    GPIOD->MODER |= (1 << 28);  // red

    USART2->BRR = 0x0683;         // 9600 baud @ 16 MHz
    USART2->CR1 |= (1U << 3);     // TE
    USART2->CR1 |= (1U << 13);    // UE
    USART2->CR1 |= (1 << 2);      // RE
}

void delay(int n)
{
    for (; n > 0; n--)
        for (volatile int i = 0; i < 2000; i++);
}

void USART2_write_str(const char *s)
{
    while (*s)
    {
        USART2_write(*s);
        s1 = s1 + *s;
        s++;
    }
}

void USART2_write(uint8_t ch)
{
    while (!(USART2->SR & (1U << 7)));   // Wait until TXE = 1
    USART2->DR = ch;
    while (!(USART2->SR & (1U << 6)));   // Wait until TC = 1
}

uint8_t USART2_read(void)
{
    while (!(USART2->SR & (1U << 5)));   // Wait until RXNE = 1
    return (uint8_t)USART2->DR;
}

void USART2_read_str(char *s)
{
    int i = 0;
    char read_ch;

    while (1)
    {
        read_ch = USART2_read();
        s2 = s2 + read_ch;

        if (read_ch == '\r')   // Enter pressed
        {
            s[i] = '\0';
            break;
        }
        s[i++] = read_ch;
    }
}

void USART2_PASS()
{
    if (s1 == s2)
    {
        GPIOD->ODR &= ~(1 << 14);
        GPIOD->ODR |= (1 << 12);
        delay(500);
    }
    else
    {
        GPIOD->ODR &= ~(1 << 12);
        GPIOD->ODR |= (1 << 14);
        delay(500);
    }
}
