#include<cstdint>
#include"stm32f407.h"
class friend_function
{
	static uint32_t count;
	void gpio_ini()
	{

		RCC->AHB1ENR|=(1<<0);
		RCC->AHB1ENR|=(1<<3);

		for(uint32_t i=12;i<=15;i++)
		{
			GPIOD->MODER&=~(3<<(i*2));
			GPIOD->MODER|=(1<<(i*2));
		}
		GPIOA->MODER&=~(3<<0);
	}
public:
	friend_function()
	{
		count=0;
	}
	friend void status();
};
uint32_t friend_function::count = 0;
void delay()
{
	for(volatile uint32_t i=0;i<5000000;i++);
}
void status()
{

    friend_function::gpio_init();
	if(GPIOA->IDR&1)
	{
		friend_function::count++;
		if(friend_function::count%4==0)
		{
			GPIOD->ODR^=(1<<12);
			delay();
		}
		else if(friend_function::count%4==1)
		{
			GPIOD->ODR^=(1<<13);
			delay();
		}
		else if(friend_function::count%4==2)
		{
			GPIOD->ODR^=(1<<14);
			delay();
		}
		else if(friend_function::count%4==3)
		{
			GPIOD->ODR^=(1<<15);
			delay();
		}
	}
}
int main()
{
	friend_function f;
	while(1)
	{
		status();
	}
}
