#include<cstdint>
#include"stm32f407.h"
void init()
{
	RCC->APB1ENR|=(1<<17);  //usart2
	RCC->AHB1ENR|=(1<<0); // gpioc
	RCC->AHB1ENR|=(1<<3);  // gpiod

GPIOA->MODER&=~(3<<4);
GPIOA->MODER|=(2<<4);
GPIOA->MODER&=~(3<<6);
GPIOA->MODER|=(2<<6);
GPIOA->AFR[0] &= ~(0xFU << 8);
GPIOA->AFR[0] |=  (7U << 8);  // AF7
GPIOA->AFR[0] &= ~(0xFU << 12);
GPIOA->AFR[0] |=  (7U << 12); // AF7

	GPIOD->MODER&=~(3<<26);
	GPIOD->MODER|=(1<<26);  // green
	GPIOD->MODER&=~(3<<28);
	GPIOD->MODER|=(1<<28);  // red

	USART2->BRR = 0x0683;         // 9600 baud @ 16 MHz
	USART2->CR1 |= (1U << 3);     // TE
	USART2->CR1 |= (1U << 13);
	USART2->CR1|=(1<<2);


}

int main()
{
	inti();
}
