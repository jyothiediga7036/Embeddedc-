#include <cstdint>
#include "stm32f407.h"

// Global flag (communication between ISR and main)
volatile uint32_t interrupt_flag = 0;

// ---------------- TIMER CLASS ----------------
class timer
{
public:
    timer()
    {
        // Enable GPIOD clock
        RCC->AHB1ENR |= (1 << 3);

        // PD13, PD14 as output
        GPIOD->MODER &= ~(3 << 26);
        GPIOD->MODER |=  (1 << 26);

        GPIOD->MODER &= ~(3 << 28);
        GPIOD->MODER |=  (1 << 28);

        // Enable TIM2 clock
        RCC->APB1ENR |= (1 << 0);

        // Configure timer for 1 sec
        TIM2->PSC = 16000 - 1;   // 16MHz → 1kHz
        TIM2->ARR = 1000 - 1;    // 1kHz → 1 sec

        TIM2->CNT = 0;

        // Enable update interrupt
        TIM2->DIER |= (1 << 0);

        // Start timer
        TIM2->CR1 |= (1 << 0);

        // Enable NVIC interrupt (TIM2 IRQ = 28)
        *(volatile uint32_t*)0xE000E100 |= (1 << 28);
    }
};

// ---------------- ISR ----------------
extern "C" void TIM2_IRQHandler(void)
{
    if (TIM2->SR & (1 << 0))   // Check overflow (UIF)
    {
        interrupt_flag = 1;    // Notify main loop

        TIM2->SR &= ~(1 << 0); // Clear flag
    }
}

// ---------------- SENSOR CLASS ----------------
class sensor
{
    float temperature;

public:
    sensor(float t = 0)
    {
        temperature = t;
    }

    void read_data()
    {
        if (temperature < 45)
        {
            GPIOD->ODR ^= (1 << 13);   // Toggle LED (green)
        }
        else
        {
            GPIOD->ODR ^= (1 << 14);   // Toggle LED (red)
        }
    }
};

// ---------------- MAIN ----------------
int main()
{
    timer t;        // Initialize timer
    sensor s(43);   // Sensor value

    while (1)
    {
        if (interrupt_flag)
        {
            interrupt_flag = 0;   // Reset flag

            s.read_data();        // Runs every 1 second
        }
    }
}



