#include"stm32f407.h"
#include<cstdint>
class observer
{
public:
	virtual void update()=0;
};
class subject
{
	observer*obj[2];
	volatile int button_pressed;
	int count;
public:
	subject()
	{
		count=0;
		button_pressed=0;
	}
	void init()
	{
		RCC->AHB1ENR |= (1 << 0);   // GPIOA
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
		GPIOA->MODER &= ~(3 << (0 * 2));
		GPIOA->PUPDR &= ~(3 << (0 * 2));
		GPIOA->PUPDR |=  (2 << (0 * 2));
		SYSCFG->EXTICR[0] &= ~(0xF << 0);  // 0000 = PA0
		EXTI->RTSR |= (1 << 0);
		EXTI->IMR |= (1 << 0);
		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
		*piser|=(1<<6);
		RCC->AHB1ENR |= (1 << 3);   // Enable GPIOD clock
		GPIOD->MODER &= ~(3 << (12 * 2));
		GPIOD->MODER |=  (1 << (12 * 2));  // Output mode
		GPIOD->ODR &= ~(1 << 12); // LED OFF
	}
	void attach(observer *l)
	{
		if(count<2)
		{
			obj[count++]=l;
		}
	}
	void notify()
	{
		for(volatile uint32_t i=0;i<count;i++)
		{
			obj[i]->update();
		}
	}
	void status()
	{
		if(button_pressed)
		{
			notify();
			button_pressed=0;
		}
	}
	void delay()
	{
		for(volatile uint32_t i=0;i<50000;i++);
	}
	void set()
	{
		button_pressed=1;
	}
};
class button:public observer
{
	subject*s;
public:
	void update()
	{
		GPIOD->ODR^=(1<<12);
	}
};
subject s;
extern "C" void EXTI0_IRQHandler(void)
{
    if (EXTI->PR & (1 << 0))  // / test triggered occur or not 1-> occur 0-> not occure
    {
        GPIOD->ODR |= (1 << 12); // Toggle LED
        s.set();

        EXTI->PR |= (1 << 0); // Clear pending
    }
}
int main()
{
	s.init();
	button b;
	s.attach(&b);
	while(1)
	{
		s.status();
	}
}
