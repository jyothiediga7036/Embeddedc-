#include<cstdint>
#include"stm32f407.h"
class friend_function
{
	static uint32_t count;
	void gipo_ini()
	{

		RCC->AHB1ENR|=(1<<0);
		RCC->AHB1ENR|=(1<<3);

		for(uint32_t i=12;i<=15;i++)
		{
			GPIOD->MODER&=~(3<<(i*2));
			GPIOD->MODER|=(2<<(i*2));
		}
		GPIOA->MODER&=~(3<<0);
	}
public:
	friend_function()
	{
		count=0;
	}
	friend void status(friend_function &obj);
};
void status(friend_function&obj)
{
	obj.gpio_init();
	if(GPIOA_IDR&1)
	{
		count++;
		if(count%4==0)
		{
			GPIOD->ODR^=(1<<12);
			delay();
		}
		else if(count%4==1)
		{
			GPIOD->ODR^=(1<<13);
			delay();
		}
		else if(count%4==2)
		{
			GPIOD->ODR^=(1<<14);
			delay();
		}
		else if(count%4==3)
		{
			GPIOD->ODR^=(1<<15);
			delay();
		}
	}

}
int main()
{
	friend_function f;
	status(f);
}
