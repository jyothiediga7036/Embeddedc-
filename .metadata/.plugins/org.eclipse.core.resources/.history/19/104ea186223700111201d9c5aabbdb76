#include<cstdint>
#include"stm32f407.h"
volatile uint32_t timer_falg=0;
volatile uint32_t external_falg=0;
class timer
{
public:
	static void timer_init()
	{
		RCC->APB1ENR|=(1<<0); // TIM2
		TIM2->PSC=16000-1;
		TIM2->ARR=1000-1;
		TIM2->CNT=0;
		TIM2->CR1=(1<<0);
		volatile uint32_t *piser=(volatile uint32_t*)(0xE000E100);
		piser|=(1<<28);  //NVIC
	}
};
extern "C" void TIM2_IRQHandler(void)
{
	if(TIM2->SR&(1<<0))  // check timer overflow
	{
		timer_flag=1;   // update flag
		TIM2->SR&=~(1<<0);   // clear
	}
}
