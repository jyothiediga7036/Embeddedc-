#include"stm32f407.h"
#include<cstdint>
typedef struct
{
	GPIOA_ID=0,
	GPIOB_ID,
	GPIOC_ID,
	GPIOD_ID,
	GPIOE_ID,
}Gpio_handle;
typedef struct
{
    USART_TypeDef *port;
    uint32_t USART_rx;
    uint32_t USART_tx;
    GPIO_TypeDef* gpio;
    uint16_t pin;
} USART_Handle;

void USART_init( USART_Handle *usart)
{
	//RCC->AHB1ENR|=(1<<pin);
	// Enable clock for GPIOC, GPIOD and USART3
	    RCC->AHB1ENR |= (1U <<gpio_handle::port);   // GPIOC
	    //RCC->AHB1ENR |= (1U << 3);   // GPIOD
	    RCC->APB1ENR |= (1U << 18);  // USART3

	    // PC10 -> USART3_TX
	    gpio->MODER &= ~(3U <<(USART_tx*2));
	    gpio->MODER |=  (2U <<(USART_tx*2));     // Alternate function mode
	    gpio->AFR[1] &= ~(0xFU << 8);
	    gpio->AFR[1] |=  (7U << 8);     // AF7

	    // PC11 -> USART3_RX
	    gpio->MODER &= ~(3U <<(USART_rx*2));
	    gpio->MODER |=  (2U <<(USART_rx*2));     // Alternate function mode
	    gpio->AFR[1] &= ~(0xFU <<12);
	    gpio->AFR[1] |=  (7U << 12);    // AF7

	    // PD13 as output
	   // GPIOD->MODER &= ~(3U << 26);
	    //GPIOD->MODER |=  (1U << 26);

	    // USART3 settings
	    port->BRR = 0x0683;            // 9600 baud @ 16 MHz
	    port->CR1 |= (1U << 3);        // TE
	    port->CR1 |= (1U << 2);        // RE
	    port->CR1 |= (1U << 13);       // UE
	}

}
