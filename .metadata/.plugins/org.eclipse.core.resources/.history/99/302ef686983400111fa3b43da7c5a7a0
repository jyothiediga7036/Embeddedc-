#include"stm32f407.h"
#include<cstdint>
typedef struct
{
    USART_TypeDef *port;
    uint32_t USART_rx;
    uint32_t USART_tx;
    GPIO_TypeDef* gpio;
} USART_Handle;

void USART_init( USART_Handle *usart)
{
	// Enable clock for GPIOC, GPIOD and USART3
	if(usart->gpio == GPIOA) RCC->AHB1ENR |= (1<<0);
	else if(usart->gpio == GPIOB) RCC->AHB1ENR |= (1<<1);
	else if(usart->gpio == GPIOC) RCC->AHB1ENR |= (1<<2);
	else if(usart->gpio == GPIOD) RCC->AHB1ENR |= (1<<3);

	    //RCC->APB1ENR |= (1U << 18);  // USART3
	 if(usart->port == USART1) RCC->APB2ENR |= (1<<4);
	 else if(usart->port == USART2) RCC->APB1ENR |= (1<<17);
	 else if(usart->port == USART3) RCC->APB1ENR |= (1<<18);

	    // PC10 -> USART3_TX
	    usart->gpio->MODER &= ~(3U <<(usart->USART_tx*2));
	    usart->gpio->MODER |=  (2U <<(usart->USART_tx*2));     // Alternate function mode
	    //usart->gpio->AFR[1] &= ~(0xFU << 8);
	    //usart->gpio->AFR[1] |=  (7U << 8);     // AF7
	    if(usart->USART_tx < 8)
	           usart->gpio->AFR[0] |= (7 << (usart->USART_tx * 4));
	    else
	           usart->gpio->AFR[1] |= (7 << ((usart->USART_tx - 8) * 4));


	    // PC11 -> USART3_RX
	    usart->gpio->MODER &= ~(3U <<(usart->USART_rx*2));
	    usart->gpio->MODER |=  (2U <<(usart->USART_rx*2));     // Alternate function mode
	    //usart->gpio->AFR[1] &= ~(0xFU <<12);
	   // usart->gpio->AFR[1] |=  (7U << 12);    // AF7
	    if(usart->USART_rx < 8)
	          usart->gpio->AFR[0] |= (7 << (usart->USART_rx * 4));
	    else
	          usart->gpio->AFR[1] |= (7 << ((usart->USART_rx - 8) * 4));


	    // PD13 as output
	   // GPIOD->MODER &= ~(3U << 26);
	    //GPIOD->MODER |=  (1U << 26);

	    // USART3 settings
	    usart->port->BRR = 0x0683;            // 9600 baud @ 16 MHz
	    usart->port->CR1 |= (1U << 3);        // TE
	    usart->port->CR1 |= (1U << 2);        // RE
	    usart->port->CR1 |= (1U << 13);       // UE
}
void USART_write(USART_Handle*usart,uint8_t ch)
{
    while (!(usart->port->SR & (1U << 7)));   // Wait until TXE = 1
    usart->port->DR = ch;
    while (!(usart->port->SR & (1U << 6)));   // Wait until TC = 1
}
void delay()
{
	for(volatile uint32_t i=0;i<500000;i++);
}
uint8_t USART1_read(USART_Handle *usart)
{
    while (!(usart->port->SR & (1 << 5))); // RXNE
    return usart->port->DR;
}

int main()
{
	 USART_Handle usart3={USART3, 10,11,GPIOC};
	 USART_init(&usart3);
	 while(1)
	 {
		 USART_write(&usart3,'A');
		 delay();
		 USART_read(&usart3);
		 delay();
	 }
}

