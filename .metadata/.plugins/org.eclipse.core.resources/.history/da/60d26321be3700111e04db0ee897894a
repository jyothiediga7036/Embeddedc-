#include<cstdint>
#include"stm32f407.h"
volatile uint32_t start=0;
volatile uint32_t stop=0;
volatile uint32_t timer=0;
class motor
{
public:
	static void EXTI3_init()
	{
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
		RCC->AHB1ENR|=(1<<1);  //gpiob

		GPIOB->MODER &= ~(3 << (3 * 2));
		GPIOB->PUPDR &= ~(3 << (3 * 2));
		GPIOB->PUPDR |=  (2 << (3 * 2));  // Pull-down

		SYSCFG->EXTICR[0]&=~(0xf<<12);
		SYSCFG->EXTICR[0]|=(1<<12);    //PB3

		EXTI->IMR|=(1<<3);
		EXTI->RTSR|=(1<<3);

		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
        *piser|=(1<<9);  // NVIC_ISER|=(1<<7);
	}
	static void EXTI4_init()
	{
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
		RCC->AHB1ENR|=(1<<2);  //gpioc

		 GPIOC->MODER &= ~(3 << (4 * 2));   // PC4 input
		 GPIOC->PUPDR &= ~(3 << (4 * 2));
		 GPIOC->PUPDR |=  (2 << (4 * 2));    // Pull-down

		SYSCFG->EXTICR[1]&=~(0xf<<0);
		SYSCFG->EXTICR[1]|=(0x2<<0);    //PC4

		EXTI->IMR|=(1<<4);   //  enable interrupt
		EXTI->RTSR|=(1<<4);  // raising edge  trigger input

		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
		        *piser|=(1<<10);  // NVIC_ISER|=(1<<7);
	}
	static void TIM2_init()
	{
		RCC->AHB1ENR |= (1 << 3);
		        // Enable TIM2 clock
		 RCC->APB1ENR |= (1 << 0);

		        // Configure timer for 1 sec
		 TIM2->PSC = 1600 - 1;   // 16MHz → 1kHz
		 TIM2->ARR = 10000 - 1;    // 1kHz → 1 sec

		 TIM2->CNT = 0;

		        // Enable update interrupt
		 TIM2->DIER |= (1 << 0);

		        // Start timer
		 TIM2->CR1 |= (1 << 0);

		        // Enable NVIC interrupt (TIM2 IRQ = 28)
		  volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
		                *piser|=(1<<28);
	 }
	static void GPIO_init()
	{
		RCC->AHB1ENR|=(1<<3);  // gpiod
		GPIOD->MODER&=~(3<<24);
		GPIOD->MODER|=(1<<24);
		GPIOD->MODER&=~(3<<28);
		GPIOD->MODER|=(1<<28);
		GPIOD->MODER&=~(3<<30);
		GPIOD->MODER|=(1<<30);

	}

};

extern "C" void EXTI3_IRQHandler(void)
{
    if (EXTI->PR & (1 << 3))  // / test triggered occur or not 1-> occur 0-> not occure
    {
        start=1;

        EXTI->PR |= (1 << 3); // Clear pending
    }
}
extern "C" void EXTI4_IRQHandler(void)
{
    if (EXTI->PR & (1 << 4))  // / test triggered occur or not 1-> occur 0-> not occure
    {
      stop=1;
      TIM2->CR1 &= ~(1 << 0); // Stop timer
      EXTI->PR |= (1 << 4); // Clear pending
    }
}
extern "C" void TIM2_IRQHandler(void)
{
    if (TIM2->SR & (1 << 0))   // Check overflow (UIF)
    {
           timer=1;// Notify main loop
           GPIOD->ODR^=(1<<15);
           TIM2->CNT = 0;
           TIM2->CR1 |= (1 << 0);

        TIM2->SR &= ~(1 << 0); // Clear flag
    }
}
int main()
{
	motor::EXTI3_init();
	motor::EXTI4_init();
	motor::TIM2_init();
	motor::GPIO_init();
	while(1)
	{
		if(start)
		{
			GPIOD->ODR|=(1<<12);
			GPIOD->ODR &= ~(1 << 14);  // Turn OFF motor LED
			start=0;
		}
		if(stop)
		{
			GPIOD->ODR &= ~(1 << 12);  // Turn OFF motor LED
			GPIOD->ODR|=(1<<14);
			stop=0;
		}
	}
}


