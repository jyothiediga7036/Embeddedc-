#include<cstdint>
#include"stm32f407.h"
class timer
{
public:
	void timer_init()
	{
		RCC->AHB1ENR|=(1<<3);  // GPIOD
		GPIOD->MODER&=~(3<<24);
		GPIOD->MODER|=(1<<24);

		RCC->APB1ENR|=(1<<0);    // TIM2
		TIM2->PSC=1600-1;      // setting Prescaler value
		TIM2->ARR=10000-1;    // setting ARR value
		TIM2->CNT=0;

	  	TIM2->DIER |= (1<<0);     //when overflow happen generate interrupt
		TIM2->CR1=(1<<0);   // start timer

		volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
	        *piser|=(1<<28);  // enable timer interrupt in NVIC_ISER
	}

};
extern "C" void TIM2_IRQHandler(void)
{
    if(TIM2->SR & (1<<0))    //Check if timer overflow happened
    {
        GPIOD->ODR ^= (1<<12);  // toggle LED

        TIM2->SR &= ~(1<<0);    // clear flag
    }
}
class sensor
{
	float tempareture;
public:
	sensor(float f=0)
	{
		tempareture=f;
	}
	void read_data()
	{
		if(tempareture<45)
		{
			GPIOD->ODR|=(1<<13);
			delay();
		}
		else
		{
			GPIOD->ODR|=(1<<14);
			delay();
		}
	}
	void delay()
	{
		for(volatile uint32_t i=0;i<500000;i++);
	}
};
