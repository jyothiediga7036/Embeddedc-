#include"stm32f407.h"
#include<cstdint>
class observer
{
public:
	void button_pressed_status()=0;
};
class subject
{
int button_pressed;
	public:
	void init()
	{
		RCC->AHB1ENR |= (1 << 0);   // GPIOA
		RCC->APB2ENR |= (1 << 14);  // SYSCFG
			GPIOA->MODER &= ~(3 << (0 * 2));
			GPIOA->PUPDR &= ~(3 << (0 * 2));
			GPIOA->PUPDR |=  (2 << (0 * 2));
			SYSCFG->EXTICR[0] &= ~(0xF << 0);  // 0000 = PA0
			EXTI->RTSR |= (1 << 0);
			EXTI->IMR |= (1 << 0);
			volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
			*piser|=(1<<6);
			RCC->AHB1ENR |= (1 << 3);   // Enable GPIOD clock
			GPIOD->MODER &= ~(3 << (12 * 2));
			GPIOD->MODER |=  (1 << (12 * 2));  // Output mode
			GPIOD->ODR &= ~(1 << 12); // LED OFF
		}
		void status()
		{
			if(button_pressed)
			{
				GPIOD->ODR|=(1<<12);
				delay();
				GPIOD->ODR&=~(1<<12);
				button_pressed=0;
			}
		}
};
class button:public observer
{
	subject*s;
public:
	void button_pressed_status()
	{
		s->button_pressed=1;
	}
};
int main()
{
	subject s;
	s.init();
	button b;
	while(1)
	{
		b.button_pressed_status();
	}
}
