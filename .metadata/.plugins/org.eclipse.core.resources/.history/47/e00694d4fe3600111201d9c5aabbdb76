#include<cstdint>
#include"stm32f407.h"
uint32_t button_pressed;

void delay()
{
	for(volatile uint32_t i=0;i<50000;i++);
}
void EXTI_init()
{
	RCC->APB2ENR |= (1 << 14);  // SYSCFG
	RCC->AHB1ENR|=(1<<1);  //gpiob

	GPIOB->MODER &= ~(3 << (1 * 2));
    GPIOB->PUPDR &= ~(3 << (1 * 2));
    GPIOB->PUPDR |=  (2 << (1 * 2));  // Pull-down

    SYSCFG->EXTICR[0]&=~(0xf<<4);
    SYSCFG->EXTICR[0]|=(1<<4);    //PB1

    EXTI->IMR|=(1<<1);
    EXTI->RTSR|=(1<<1);

    volatile uint32_t*piser=((volatile uint32_t*)(0xE000E100)); // NVIC_ISER
        *piser|=(1<<7);  // NVIC_ISER|=(1<<7);
}
extern "C" void EXTI0_IRQHandler(void)
{
    if (EXTI->PR & (1 << 1))  // / test triggered occur or not 1-> occur 0-> not occure
    {
        GPIOD->ODR |= (1 << 12); // Toggle LED
        button_pressed=1;

        EXTI->PR |= (1 << 1); // Clear pending
    }
}
class gpio
{
public:
	void led_init()
	{
		RCC->AHB1ENR|=(1<<3);  // gpiod
		RCC->AHB1ENR|=(1<<0);  // gpioa
		GPIOA->MODER&=~(3<<0);
		for(int i=12;i<=15;i++)
		{
			GPIOD->MODER&=~(3<<(i*2));
			GPIOD->MODER|=(1<<(i*2));
		}
	}
	void led_on()
	{
		GPIOD->ODR|=(1<<12);
		delay();
		GPIOD->ODR|=(1<<13);
		delay();
		GPIOD->ODR|=(1<<14);
		delay();
		GPIOD->ODR|=(1<<15);
		delay();
	}
	void led_off()
	{
		GPIOD->ODR&=~(1<<12);
		GPIOD->ODR&=~(1<<13);
		GPIOD->ODR&=~(1<<14);
		GPIOD->ODR&=~(1<<15);

	}

};
int main()
{
	EXTI_init();
	gpio g;
	g.led_init();
	while(1)
	{
		if(button_pressed)
		{
			button_pressed=0;
			g.led_on();
		}
		else
		{
			g.led_off();
		}
	}

}
