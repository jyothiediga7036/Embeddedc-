#include <stdint.h>
#include "stm32f407.h"

void USART2_Init(void);
void GPIO_Init(void);
void USART2_write(uint8_t ch);

uint8_t ch;   // ✅ global variable

int main(void)
{
    GPIO_Init();
    USART2_Init();

    while (1)
    {
        USART2_write('A');
    }
}

void GPIO_Init(void)
{
    RCC->AHB1ENR |= (1 << 0); // GPIOA
    RCC->AHB1ENR |= (1 << 3); // GPIOD

    // PA2 (TX), PA3 (RX)
    GPIOA->MODER &= ~(0xF << 4);
    GPIOA->MODER |=  (0xA << 4);

    // AF7 for PA2 and PA3
    GPIOA->AFR[0] &= ~(0xFF << 8);
    GPIOA->AFR[0] |=  (0x77 << 8);

    // PD13 output (LED)
    GPIOD->MODER &= ~(3 << 26);
    GPIOD->MODER |=  (1 << 26);
}

void USART2_Init(void)
{
    RCC->APB1ENR |= (1 << 17);

    USART2->BRR = 0x683;

    USART2->CR1 |= (1 << 2);   // RE
    USART2->CR1 |= (1 << 3);   // TE
    USART2->CR1 |= (1 << 5);   // RXNE interrupt
    USART2->CR1 |= (1 << 13);  // UE

    // NVIC enable USART2 interrupt
    volatile uint32_t *piser = (uint32_t*)0xE000E100;
    *piser |= (1 << 38);   // ✅ Correct IRQ position
}

void USART2_write(uint8_t ch)
{
    while (!(USART2->SR & (1 << 7))); // TXE
    USART2->DR = ch;
}

extern "C" void USART2_IRQHandler(void)
{
    if (USART2->SR & (1 << 5)) // RXNE
    {
        ch = USART2->DR;

        // Toggle LED
        GPIOD->ODR ^= (1 << 13);

        while (!(USART2->SR & (1 << 7)));
        USART2->DR = ch; // echo
    }
}
