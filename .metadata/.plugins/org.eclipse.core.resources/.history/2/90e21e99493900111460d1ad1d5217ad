void vDriverAssistanceTask(void *pvParameters )
{
        Sensor_status* sptr= (Sensor_status*)pvParameters;
	Priority = uxTaskPriorityGet(NULL);
	  while(1)
	    {

	        if(sptr->coll == false)
	        {
	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);   // Green ON
	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF
	        }

	        // simulate collision
	        count1++;

	        if(count1 >= 2500 && sptr->coll == false)
	        {
	            sptr->coll = true;   // trigger emergency
	        }

	        // stop green during collision
	        if(sptr->coll == true)
	        {
	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_RESET); // Green OFF
	            vTaskPrioritySet(xEmergencyHandle,(Priority1+2));
	            Priority1 = uxTaskPriorityGet(xEmergencyHandle);
	        }

	        vTaskDelay(pdMS_TO_TICKS(10));
	    }
}
void vEmergencySystemTask(void *pvParameters )
{
        Sensor_status* sptr= (Sensor_status*)pvParameters;

	Priority1 = uxTaskPriorityGet(NULL);
	 while(1)
	    {
		 count2++;
	        if(sptr->coll == true)
	        {
	            sptr->airbag = true;
	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET); // Red ON

	           vTaskDelay(pdMS_TO_TICKS(50)); // emergency duration
	           HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_RESET);

	            sptr->airbag = false;
	           	sptr->coll = false;

	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_SET);// Orange ON
	            vTaskDelay(pdMS_TO_TICKS(20)); // recovery duration
	            HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);

	            vTaskPrioritySet(xEmergencyHandle,2);
	            Priority1 = uxTaskPriorityGet(xEmergencyHandle);

	            // Reset system → back to driving

	            count1 = 0;
	            count2 = 0;
	            /*if(count1==0&& count2==0)
	            {
	            	//HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_RESET);
	            	HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_SET);// Orange ON
	            	vTaskDelay(pdMS_TO_TICKS(20)); // recovery duration
	            	HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);

	            }
*/
	            //HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET); // Orange OFF
	        }

	        vTaskDelay(pdMS_TO_TICKS(10));
	    }
}


